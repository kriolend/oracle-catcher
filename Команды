# ── Каждая папка terraform/<имя>/ содержит ──
# providers.tf      — Настройка GCP
# variables.tf      — Переменные (Project ID, Region)
# backend.tf        — Стейт в облаке (GCS bucket)
# main.tf           — Сеть, фаерволы, виртуалки e2-micro
# outputs.tf        — IP адреса (для Ansible)
# terraform.tfvars  — Значения переменных (в .gitignore!)

# ============================================
# ПОЛНАЯ ПОСЛЕДОВАТЕЛЬНОСТЬ РАЗВЁРТЫВАНИЯ
# ============================================
# ⚠️  ВАЖНО: Выполняй команды строго по порядку. Не пропускай шаги!

# ── ЭТАП 1: Создание сети и первой ноды (Terraform vyacheslav) ──
# Что делает: Создаёт облачную сеть, фаерволы и первую виртуальную машину.
# Зачем: Вся дальнейшая инфраструктура подключается к этой сети.
# Как выполнить:
cd ~/Projects/devops-enterprise-lab/terraform/vyacheslav
gcloud auth application-default login          # Выбрать: vyacheslav.rumyancev@gmail.com
gcloud storage buckets create gs://devops-lab-tfstate-vr-2026 --location=us-central1
terraform init
terraform apply
# ✅ Проверка перед переходом: Должен появиться 1 работающий сервер с внешним IP.
# Команда проверки:
gcloud compute instances list --format="table(name, status, networkInterfaces[0].accessConfigs[0].natIP)"

# ── ЭТАП 2: Добавление второй ноды (Terraform kriolend) ──
# Что делает: Создаёт вторую ВМ и подключает её к уже существующей сети.
# Зачем: Получаем второй узел для кластера Kubernetes.
# Как выполнить:
cd ~/Projects/devops-enterprise-lab/terraform
cp -r vyacheslav kriolend
cd kriolend
rm -rf .terraform .terraform.lock.hcl
gcloud config set project my-devops-project-20260317
gcloud auth login                              # Выбрать: kriolend@gmail.com
gcloud auth application-default login          # Выбрать: kriolend@gmail.com

# Отредактируй 3 файла вручную:
#   1. terraform.tfvars  → gcp_project_id = "my-devops-project-20260317"
#   2. backend.tf        → bucket = "devops-lab-tfstate-kriolend-v2"
#   3. main.tf           → name = "k3s-kriolend", используй существующую сеть

gcloud storage buckets create gs://devops-lab-tfstate-kriolend-v2 --location=us-central1
terraform init -reconfigure
terraform apply -reconfigure
# ✅ Проверка перед переходом: Должны быть 2 работающих сервера (vyacheslav + kriolend).

# ── ЭТАП 3: Добавление третьей ноды (Terraform u8197250572) ──
# Что делает: Аналогично этапу 2, но для третьего аккаунта.
# Зачем: Получаем мастер-узел для Kubernetes.
cp -r vyacheslav u8197250572
cd u8197250572
rm -rf .terraform .terraform.lock.hcl
gcloud config set project packer-images-490319
gcloud auth login                              # Выбрать: u8197250572@gmail.com
gcloud auth application-default login          # Выбрать: u8197250572@gmail.com

# Отредактируй те же 3 файла:
#   1. terraform.tfvars  → gcp_project_id = "packer-images-490319"
#   2. backend.tf        → bucket = "devops-lab-tfstate-u8197250572"
#   3. main.tf           → name = "k3s-u8197250572", используй существующую сеть

gcloud storage buckets create gs://devops-lab-tfstate-u8197250572 --location=us-central1
terraform init -reconfigure
terraform apply -reconfigure
# ✅ Проверка перед переходом: Должно быть 3 работающих сервера с разными IP.

# ── ЭТАП 4: Базовая настройка системы (Ansible 01_system_setup) ──
# Что делает: Отключает swap, оптимизирует ядро Linux, удаляет лишние службы.
# Зачем: Делает ноды готовыми к работе Kubernetes (k3s не работает с swap).
# Как выполнить:
cd ~/Projects/devops-enterprise-lab/ansible
ansible-playbook playbooks/01_system_setup.yml
# ✅ Проверка перед переходом: Все серверы доступны и система оптимизирована.
# Команда проверки:
ansible all -m ping

# ── ЭТАП 5: Установка K3s кластера (Ansible 02_k3s_deploy) ──
# Что делает: Устанавливает k3s (1 мастер + 2 воркера) и настраивает кластер.
# Зачем: Создаётся готовый Kubernetes-кластер для разворачивания приложений.
# Как выполнить:
ansible-playbook playbooks/02_k3s_deploy.yml
# ✅ Проверка перед переходом: Кластер запущен, ноды в статусе Ready.
# Команда проверки:
kubectl get nodes

# ── ЭТАП 6: Деплой Oracle Catcher (Ansible 03_oracle_catcher) ──
# Что делает: Разворачивает скрипт для автоматического перехвата бесплатных ARM нод.
# Зачем: Запускается фоновый процесс для сбора ресурсов Oracle Cloud.
# Как выполнить:
ansible-playbook playbooks/03_oracle_catcher.yml --ask-vault-pass
# ✅ Финальная проверка: Процесс запущен и логи без ошибок.
# Команда проверки:
sudo systemctl status oracle_catcher.service
sudo journalctl -u oracle_catcher.service -f -n 50

